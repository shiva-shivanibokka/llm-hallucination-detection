# Base URL of the FastAPI backend. Exposed to the browser (NEXT_PUBLIC_*)
# because GET requests are made client-side.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Bearer token for the backend API. Server-only — do NOT prefix with
# NEXT_PUBLIC_. Read only by the /api/proxy route handler, which attaches it
# to mutating (POST/DELETE) requests so it is never shipped to the browser.
APP_API_TOKEN=
